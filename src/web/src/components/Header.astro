---
import { getUI } from "../lib/content";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const ui = getUI(lang);

const navItems = [
  { href: `/${lang}`, label: ui?.nav?.home ?? "Home" },
  { href: `/${lang}/features`, label: ui?.nav?.features ?? "Features" },
  { href: `/${lang}/privacy`, label: ui?.nav?.privacy ?? "Privacy" },
  { href: `/${lang}/support`, label: ui?.nav?.support ?? "Support" },
  { href: `/${lang}/about`, label: ui?.nav?.about ?? "About" },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === `/${lang}`) {
    return currentPath === href || currentPath === `/${lang}/`;
  }
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header class="site-header">
  <div class="container inner">
    <a href={`/${lang}`} class="brand" aria-label="Qibla Now home">
      <img src="/appicon.png" alt="Qibla Now logo" class="brand-logo" />
      <span class="brand-text">Qibla Now</span>
    </a>

    <nav aria-label="Primary">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} class={isActive(item.href) ? "active" : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-controls">
      <LanguageSwitcher lang={lang} selectLabel={ui?.lang?.select ?? "Language"} />
      <ThemeToggle
        toggleLightLabel={ui?.theme?.toggleLight ?? "Switch to light mode"}
        toggleDarkLabel={ui?.theme?.toggleDark ?? "Switch to dark mode"}
      />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--header-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .inner {
    min-height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 800;
    flex-shrink: 0;
    text-decoration: none;
  }

  .brand-logo {
    display: block;
    width: 38px;
    height: 38px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .brand-text {
    white-space: nowrap;
    color: var(--brand-dark);
    font-weight: 800;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 0.15rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  nav a {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    padding: 0.4rem 0.75rem;
    color: var(--muted);
    font-weight: 600;
    font-size: 0.9rem;
    border-bottom: 2px solid transparent;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  nav a:hover {
    color: var(--text);
    text-decoration: none;
  }

  nav a.active {
    color: var(--brand-dark);
    border-bottom-color: var(--brand);
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  @media (max-width: 760px) {
    .inner {
      padding-top: 0.65rem;
      padding-bottom: 0.65rem;
      align-items: flex-start;
      flex-direction: column;
      gap: 0.5rem;
    }

    nav ul {
      justify-content: flex-start;
    }

    .header-controls {
      align-self: flex-end;
    }
  }
</style>
