---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/features", label: "Features" },
  { href: "/privacy", label: "Privacy" },
  { href: "/support", label: "Support" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container inner">
    <a href="/" class="brand" aria-label="Qibla Now home">
      <img src="/appicon.png" alt="Qibla Now logo" class="brand-logo" />
      <span class="brand-text">Qibla Now</span>
    </a>

    <nav aria-label="Primary">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class={currentPath === item.href ? "active" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(245, 243, 231, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .inner {
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  .brand-logo {
    display: block;
    width: 40px;
    height: 40px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .brand-text {
    white-space: nowrap;
    color: var(--brand-dark);
    font-weight: 800;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  nav a {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    padding: 0.5rem 0.85rem;
    color: var(--muted);
    font-weight: 600;
    border-bottom: 2px solid transparent;
  }

  nav a.active {
    color: var(--brand-dark);
    border-bottom-color: var(--brand);
  }

  @media (max-width: 720px) {
    .inner {
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
      align-items: flex-start;
      flex-direction: column;
    }

    nav ul {
      justify-content: flex-start;
    }
  }
</style>
