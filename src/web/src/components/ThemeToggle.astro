---
interface Props {
  toggleLightLabel?: string;
  toggleDarkLabel?: string;
}

const { toggleLightLabel = 'Switch to light mode', toggleDarkLabel = 'Switch to dark mode' } =
  Astro.props;
---

<button
  id="theme-toggle"
  class="theme-btn"
  aria-label={toggleDarkLabel}
  data-light-label={toggleLightLabel}
  data-dark-label={toggleDarkLabel}
  title={toggleDarkLabel}
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle') as HTMLButtonElement | null;

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    if (btn) {
      const isDark = theme === 'dark';
      btn.setAttribute(
        'aria-label',
        isDark
          ? (btn.dataset.lightLabel ?? 'Switch to light mode')
          : (btn.dataset.darkLabel ?? 'Switch to dark mode')
      );
    }
  }

  // Sync button state on load
  const current = document.documentElement.getAttribute('data-theme') ?? 'light';
  if (btn) {
    const isDark = current === 'dark';
    btn.setAttribute(
      'aria-label',
      isDark
        ? (btn.dataset.lightLabel ?? 'Switch to light mode')
        : (btn.dataset.darkLabel ?? 'Switch to dark mode')
    );
  }

  btn?.addEventListener('click', () => {
    const next =
      document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    applyTheme(next);
  });
</script>

<style>
  .theme-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .theme-btn:hover {
    color: var(--text);
    border-color: var(--brand);
  }

  /* Show moon in light mode, sun in dark mode */
  .icon-sun {
    display: none;
  }

  .icon-moon {
    display: block;
  }

  :global([data-theme='dark']) .icon-sun {
    display: block;
  }

  :global([data-theme='dark']) .icon-moon {
    display: none;
  }
</style>
