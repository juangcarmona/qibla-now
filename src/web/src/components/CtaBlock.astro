---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary';
  external?: boolean;
}

const { href, label, variant = 'primary', external = false } = Astro.props;
---

<a
  href={href}
  class={`button button-${variant}`}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  {label}
</a>
