---
interface Props {
  eyebrow?: string;
  title: string;
  bodyPara1: string;
  bodyPara2: string;
  primaryLabel: string;
  emailAlt?: string;
  microNote?: string;
  mailtoBody?: string;
}

const {
  eyebrow,
  title,
  bodyPara1,
  bodyPara2,
  primaryLabel,
  emailAlt,
  microNote,
  mailtoBody = 'Hi, I want to join as a tester.',
} = Astro.props;

const EMAIL = 'juan@jgcarmona.com';
const MAILTO =
  `mailto:${EMAIL}?subject=Qibla%20Now%20Tester&body=${encodeURIComponent(mailtoBody)}`;
---

<section class="tester-cta section" aria-labelledby="tester-cta-heading">
  <div class="card tester-inner">
    <div class="tester-content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 id="tester-cta-heading">{title}</h2>
      <p class="tester-body">{bodyPara1}</p>
      <p class="tester-body tester-body--emphasis">{bodyPara2}</p>
    </div>

    <div class="tester-actions">
      <a
        class="button button-primary"
        href={MAILTO}
        aria-label={primaryLabel}
      >{primaryLabel}</a>

      {emailAlt && (
        <p class="tester-email-line">
          {emailAlt}{' '}
          <a
            href={MAILTO}
            class="tester-email-link"
            aria-label={`Send email to ${EMAIL}`}
          >{EMAIL}</a>
        </p>
      )}

      {microNote && <p class="tester-micro">{microNote}</p>}
    </div>
  </div>
</section>

<style>
  .tester-inner {
    display: grid;
    gap: 2rem;
    padding: 2rem;
    border-left: 4px solid var(--brand);
  }

  .tester-content h2 {
    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tester-body {
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .tester-body--emphasis {
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0;
  }

  .tester-actions {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.85rem;
  }

  .tester-email-line {
    margin: 0;
    font-size: 0.92rem;
    color: var(--muted);
  }

  .tester-email-link {
    color: var(--brand-dark);
    text-decoration: underline;
  }

  .tester-email-link:hover {
    color: var(--brand);
  }

  .tester-email-link:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .tester-micro {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .button-primary:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 3px;
  }

  @media (min-width: 700px) {
    .tester-inner {
      grid-template-columns: minmax(0, 1.6fr) minmax(220px, 1fr);
      align-items: center;
    }
  }
</style>
