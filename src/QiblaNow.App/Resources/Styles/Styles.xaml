<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui">

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#000000}" />
        <Setter Property="BackgroundColor" Value="#2B5B84" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
        <Setter Property="BackgroundColor" Value="#FFFFFF" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="PlaceholderColor" Value="#999999" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

</ResourceDictionary>
