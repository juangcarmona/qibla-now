<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:QiblaNow.Presentation.ViewModels;assembly=QiblaNow.Presentation"
             x:Class="QiblaNow.App.Pages.CalculationSettingsPage"
             xmlns:app="clr-namespace:QiblaNow.App"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:QiblaNow.App.Resources.Localization"
             Title="{x:Static loc:AppResources.CalculationSettings_Title}"
             BackgroundColor="{StaticResource AppBackgroundLight}"
             x:DataType="viewmodels:SettingsViewModel">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,16,20,20" Spacing="16">

                <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="18">

                        <Label Text="{x:Static loc:AppResources.CalculationSettings_Header}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                        <!-- Calculation Method -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{x:Static loc:AppResources.CalculationSettings_Method}"
                               FontSize="13" TextColor="{StaticResource Gray600}" />
                            <Picker ItemsSource="{Binding CalculationMethodOptions}"
                                SelectedItem="{Binding SelectedMethod}"
                                Title="{x:Static loc:AppResources.CalculationSettings_SelectMethod}"
                                HorizontalOptions="Fill" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="0.5" Color="{StaticResource Gray200}" />

                        <!-- Madhab -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{x:Static loc:AppResources.CalculationSettings_Madhab}"
                               FontSize="13" TextColor="{StaticResource Gray600}" />
                            <Picker ItemsSource="{Binding MadhabOptions}"
                                SelectedItem="{Binding SelectedMadhab}"
                                Title="{x:Static loc:AppResources.CalculationSettings_SelectMadhab}"
                                HorizontalOptions="Fill" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="0.5" Color="{StaticResource Gray200}" />

                        <!-- High Latitude Rule -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{x:Static loc:AppResources.CalculationSettings_HighLatitudeRule}"
                               FontSize="13" TextColor="{StaticResource Gray600}" />
                            <Picker ItemsSource="{Binding HighLatitudeRuleOptions}"
                                SelectedItem="{Binding SelectedHighLatitudeRule}"
                                Title="{x:Static loc:AppResources.CalculationSettings_SelectRule}"
                                HorizontalOptions="Fill" />
                        </VerticalStackLayout>

                        <Label Text="{x:Static loc:AppResources.CalculationSettings_AutoSave}"
                           FontSize="12" Opacity="0.6"
                           TextColor="{StaticResource Gray500}"
                           HorizontalTextAlignment="Center"
                           Margin="0,4,0,0" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="0,4">
            <admob:MTAdView
               x:Name="BottomBanner"                
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>