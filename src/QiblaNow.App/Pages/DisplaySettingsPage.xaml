<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QiblaNow.App.Pages.DisplaySettingsPage"
             xmlns:app="clr-namespace:QiblaNow.App"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:QiblaNow.App.Resources.Localization"
             Title="{x:Static loc:AppResources.DisplaySettings_Title}"
             BackgroundColor="{StaticResource AppBackgroundLight}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,16,20,20" Spacing="16">

                <!-- Time Format (future) -->
                <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">
                        <Label Text="{x:Static loc:AppResources.DisplaySettings_TimeFormat}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                               Text="{x:Static loc:AppResources.DisplaySettings_24HourClock}"
                               FontSize="15"
                               TextColor="{StaticResource OnSurfaceLight}"
                               VerticalOptions="Center" />
                            <Switch Grid.Column="1"
                                IsEnabled="False"
                                OnColor="{StaticResource Primary}" />
                        </Grid>

                        <Label Text="{x:Static loc:AppResources.DisplaySettings_TimeFormatComingSoon}"
                           FontSize="12" Opacity="0.55"
                           TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Prayer Visibility (future) -->
                <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static loc:AppResources.DisplaySettings_PrayerVisibility}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Text="{x:Static loc:AppResources.DisplaySettings_PrayerVisibilityComingSoon}"
                           FontSize="13" TextColor="{StaticResource Gray500}"
                           LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Hijri Date Adjustment (future) -->
                <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static loc:AppResources.DisplaySettings_HijriAdjustment}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Text="{x:Static loc:AppResources.DisplaySettings_HijriAdjustmentComingSoon}"
                           FontSize="13" TextColor="{StaticResource Gray500}"
                           LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="0,4">
            <admob:MTAdView
               x:Name="BottomBanner"                
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
