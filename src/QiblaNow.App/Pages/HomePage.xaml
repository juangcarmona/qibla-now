<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="QiblaNow.App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:QiblaNow.Presentation.ViewModels;assembly=QiblaNow.Presentation"
    x:DataType="viewmodels:HomeViewModel"
    Title="Qibla Now"
    BackgroundColor="{StaticResource AppBackgroundLight}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Order="Primary"
                 Priority="0"
                 Command="{Binding GoSettingsCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                FontFamily="MaterialIcons"
                Glyph="&#xE8B8;"
                Color="White"
                Size="32" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <!-- Root: TopBar + Content -->
    <Grid RowDefinitions="Auto,*">

        <!-- CONTENT -->
        <Grid Grid.Row="0"
              Padding="20"
              RowSpacing="14"
              RowDefinitions="Auto,Auto,Auto,Auto">

            <!-- ROW 0: NEXT PRAYER STATUS -->
            <Grid Grid.Row="0"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="10">

                <!-- Top line -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Next prayer"
                               FontSize="12"
                               Opacity="0.60"
                               TextColor="{StaticResource OnSurfaceLight}" />

                        <Label Text="{Binding NextPrayerName}"
                               FontSize="32"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               TextColor="{StaticResource OnSurfaceLight}" />
                    </VerticalStackLayout>

                    <Label Grid.Column="1"
                           Text="{Binding NextPrayerTime}"
                           FontSize="20"
                           FontAttributes="Bold"
                           Opacity="0.75"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="End"
                           TextColor="{StaticResource OnSurfaceLight}" />
                </Grid>

                <!-- Countdown pill -->
                <Border Grid.Row="1"
                        Padding="12,8"
                        BackgroundColor="{StaticResource White}"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>

                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <BoxView WidthRequest="8"
                                 HeightRequest="8"
                                 CornerRadius="4"
                                 Opacity="0.75"
                                 Color="{StaticResource Primary}" />

                        <Label Text="{Binding NextPrayerCountdown}"
                               FontSize="14"
                               Opacity="0.85"
                               TextColor="{StaticResource OnSurfaceLight}" />
                    </HorizontalStackLayout>
                </Border>

            </Grid>

            <!-- ROW 1: SCHEDULE CARD -->
            <Frame Grid.Row="1"
                   Padding="16"
                   HasShadow="True"
                   BackgroundColor="{StaticResource White}">

                <VerticalStackLayout Spacing="14">

                    <!-- Header: date label with nav + location -->
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">

                        <!-- Day navigation -->
                        <Grid Grid.Column="0"
                              ColumnDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="2"
                              VerticalOptions="Center">

                            <Button Grid.Column="0"
                                    Text="&#x2039;"
                                    Command="{Binding PreviousDayCommand}"
                                    WidthRequest="32"
                                    HeightRequest="32"
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    FontSize="20"
                                    TextColor="{StaticResource Primary}" />

                            <Label Grid.Column="1"
                                   Text="{Binding SelectedDateLabel}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource OnSurfaceLight}" />

                            <Button Grid.Column="2"
                                    Text="&#x203A;"
                                    Command="{Binding NextDayCommand}"
                                    WidthRequest="32"
                                    HeightRequest="32"
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    FontSize="20"
                                    TextColor="{StaticResource Primary}" />
                        </Grid>

                        <!-- Location label + optional Today tap-target -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding LocationLabel}"
                                   FontSize="12"
                                   Opacity="0.65"
                                   HorizontalTextAlignment="End"
                                   TextColor="{StaticResource OnSurfaceLight}" />
                            <Label Text="&#x2192; Today"
                                   FontSize="11"
                                   IsVisible="{Binding IsNotToday}"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="End">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoTodayCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- Prayer rows (data-driven, Sunrise excluded) -->
                    <VerticalStackLayout Spacing="12"
                                         BindableLayout.ItemsSource="{Binding PrayerRows}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:PrayerRowItem">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           Opacity="0.85"
                                           VerticalTextAlignment="Center"
                                           TextColor="{StaticResource OnSurfaceLight}" />
                                    <BoxView Grid.Column="1"
                                             HeightRequest="1"
                                             Opacity="0.10"
                                             VerticalOptions="Center"
                                             BackgroundColor="{StaticResource OnSurfaceLight}" />
                                    <Label Grid.Column="2"
                                           Text="{Binding Time}"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center"
                                           TextColor="{StaticResource OnSurfaceLight}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Meta: method + asr (bound to actual settings) -->
                    <HorizontalStackLayout Spacing="10" Opacity="0.65">
                        <Label Text="{Binding MethodLabel}"
                               FontSize="12"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Text="&#x2022;"
                               FontSize="12"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Text="{Binding AsrLabel}"
                               FontSize="12"
                               TextColor="{StaticResource OnSurfaceLight}" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- ROW 2: BOTTOM ACTIONS -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10">

                <Button Text="Qibla"
                        HeightRequest="54"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoQiblaCommand}" />

                <Button Grid.Column="1"
                        Text="Map"
                        HeightRequest="54"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoMapCommand}" />

                <Button Grid.Column="2"
                        Text="Alarms"
                        HeightRequest="54"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoTimesCommand}" />
            </Grid>

            <!-- ROW 3: ADS SLOT -->
            <Frame Grid.Row="3"
                   HeightRequest="64"
                   HasShadow="False"
                   Padding="0"
                   BackgroundColor="{StaticResource Black}"
                   Opacity="0.05" />

        </Grid>

    </Grid>
</ContentPage>