<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="QiblaNow.App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:QiblaNow.Presentation.ViewModels;assembly=QiblaNow.Presentation"
    xmlns:app="clr-namespace:QiblaNow.App"
    xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"   
    x:DataType="viewmodels:HomeViewModel"
    Title="Qibla Now"
    BackgroundColor="{StaticResource AppBackgroundLight}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Order="Primary"
                     Priority="0"
                     Command="{Binding GoSettingsCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="MaterialIcons"
                    Glyph="&#xE8B8;"
                    Color="White"
                    Size="28" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,16,20,20" Spacing="14">

                <!-- PRAYER TIMES CARD -->
                <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="14">

                        <!-- Location -->
                        <Label Text="{Binding LocationLabel}"
                           FontSize="{OnIdiom Default=24, Tablet=30}"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource OnSurfaceLight}" />

                        <!-- Date navigation row -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12"
                          VerticalOptions="Center">

                            <Button Grid.Column="0"
                                Text="&#x2039;"
                                Command="{Binding PreviousDayCommand}"
                                WidthRequest="36"
                                HeightRequest="36"
                                Padding="0"
                                CornerRadius="18"
                                BackgroundColor="Transparent"
                                FontSize="22"
                                TextColor="{StaticResource Primary}" />

                            <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                                <Label Text="{Binding SelectedDateLabel}"
                                   FontSize="{OnIdiom Default=18, Tablet=22}"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource OnSurfaceLight}" />

                                <Label Text="Tap to go back to today"
                                   FontSize="12"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{StaticResource Primary}"
                                   IsVisible="{Binding IsNotToday}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoTodayCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                Text="&#x203A;"
                                Command="{Binding NextDayCommand}"
                                WidthRequest="36"
                                HeightRequest="36"
                                Padding="0"
                                CornerRadius="18"
                                BackgroundColor="Transparent"
                                FontSize="22"
                                TextColor="{StaticResource Primary}" />
                        </Grid>

                        <Label Text="{Binding HijriDateLabel}"
                           FontSize="14"
                           Opacity="0.65"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding HasHijriDate}"
                           TextColor="{StaticResource OnSurfaceLight}" />

                        <VerticalStackLayout Spacing="8"
                                         Margin="0,6,0,0"
                                         BindableLayout.ItemsSource="{Binding PrayerRows}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:PrayerRowItem">
                                    <Border Padding="10,8"
                                        BackgroundColor="Transparent"
                                        StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>

                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsHighlighted}"
                                                     Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                                <Setter Property="Stroke" Value="{StaticResource Tertiary}" />
                                                <Setter Property="StrokeThickness" Value="1" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                          ColumnSpacing="10"
                                          Padding="0">

                                            <Label Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="{OnIdiom Default=16, Tablet=19}"
                                               VerticalTextAlignment="Center"
                                               TextColor="{StaticResource OnSurfaceLight}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsHighlighted}"
                                                             Value="True">
                                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                                        <Setter Property="FontAttributes" Value="Bold" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>

                                            <!-- Per-prayer alarm indicator -->
                                            <Label Grid.Column="1"
                                               FontFamily="MaterialIcons"
                                               Text="&#xE7F6;"
                                               FontSize="{OnIdiom Default=14, Tablet=17}"
                                               Opacity="0.30"
                                               TextColor="{StaticResource OnSurfaceLight}"
                                               VerticalTextAlignment="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                             Binding="{Binding AlarmEnabled}"
                                                             Value="True">
                                                        <Setter Property="Text"      Value="&#xE7F4;" />
                                                        <Setter Property="Opacity"   Value="1.0" />
                                                        <Setter Property="TextColor" Value="{StaticResource Tertiary}" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>

                                            <BoxView Grid.Column="2"
                                                 HeightRequest="1"
                                                 Opacity="0.12"
                                                 VerticalOptions="Center"
                                                 BackgroundColor="{StaticResource OnSurfaceLight}">
                                                <BoxView.Triggers>
                                                    <DataTrigger TargetType="BoxView"
                                                             Binding="{Binding IsHighlighted}"
                                                             Value="True">
                                                        <Setter Property="Opacity" Value="0.06" />
                                                        <Setter Property="BackgroundColor" Value="{StaticResource Tertiary}" />
                                                    </DataTrigger>
                                                </BoxView.Triggers>
                                            </BoxView>

                                            <Label Grid.Column="3"
                                               Text="{Binding Time}"
                                               FontSize="{OnIdiom Default=16, Tablet=19}"
                                               HorizontalTextAlignment="End"
                                               VerticalTextAlignment="Center"
                                               TextColor="{StaticResource OnSurfaceLight}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsHighlighted}"
                                                             Value="True">
                                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                                        <Setter Property="FontAttributes" Value="Bold" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4"
                                         HorizontalOptions="Center"
                                         Margin="0,4,0,0">

                            <HorizontalStackLayout Spacing="6"
                                               HorizontalOptions="Center">
                                <Label Text="{Binding NextPrayerPrefix}"
                                   FontSize="{OnIdiom Default=15, Tablet=19}"
                                   TextColor="{StaticResource OnSurfaceLight}" />
                                <Label Text="{Binding NextPrayerName}"
                                   FontSize="{OnIdiom Default=15, Tablet=19}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Tertiary}" />
                                <Label Text="{Binding NextPrayerTime}"
                                   FontSize="{OnIdiom Default=15, Tablet=19}"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurfaceLight}" />
                                <!-- Bell icon: muted/off by default, colored when alarm is on -->
                                <Label FontFamily="MaterialIcons"
                                   Text="&#xE7F6;"
                                   FontSize="15"
                                   Opacity="0.35"
                                   TextColor="{StaticResource OnSurfaceLight}"
                                   VerticalTextAlignment="Center"
                                   IsVisible="{Binding ShowLiveCountdown}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                 Binding="{Binding NextPrayerAlarmEnabled}"
                                                 Value="True">
                                            <Setter Property="Text"    Value="&#xE7F4;" />
                                            <Setter Property="Opacity" Value="1.0" />
                                            <Setter Property="TextColor" Value="{StaticResource Tertiary}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </HorizontalStackLayout>

                            <Label Text="{Binding NextPrayerCountdown}"
                               FontSize="{OnIdiom Default=32, Tablet=42}"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Tertiary}"
                               IsVisible="{Binding ShowLiveCountdown}" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="8"
                                           HorizontalOptions="Center"
                                           Opacity="0.7"
                                           Margin="0,6,0,0">
                            <Label Text="Calculation Method:"
                               FontSize="{OnIdiom Default=13, Tablet=16}"
                               TextColor="{StaticResource OnSurfaceLight}" />
                            <Label Text="{Binding MethodLabel}"
                               FontSize="{OnIdiom Default=13, Tablet=16}"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />
                            <Label Text="•"
                               FontSize="{OnIdiom Default=13, Tablet=16}"
                               TextColor="{StaticResource OnSurfaceLight}" />
                            <Label Text="{Binding AsrLabel}"
                               FontSize="{OnIdiom Default=13, Tablet=16}"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*,*"
                  ColumnSpacing="10"
                  Margin="0,8,0,0">

                    <Button Text="Qibla"
                        HeightRequest="52"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoQiblaCommand}" />

                    <Button Grid.Column="1"
                        Text="Map"
                        HeightRequest="52"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoMapCommand}" />

                    <Button Grid.Column="2"
                        Text="Alarms"
                        HeightRequest="52"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoNotificationSettingsCommand}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>