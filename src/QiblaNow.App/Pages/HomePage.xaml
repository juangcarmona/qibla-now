<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="QiblaNow.App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:QiblaNow.App.ViewModels"
    x:DataType="viewmodels:HomeViewModel"
    Title="Qibla Now"
    BackgroundColor="{StaticResource AppBackgroundLight}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Order="Primary"
                 Priority="0"
                 Command="{Binding GoSettingsCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                FontFamily="MaterialIcons"
                Glyph="&#xE8B8;"
                Color="White"
                Size="32" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <!-- Root: TopBar + Content -->
    <Grid RowDefinitions="Auto,*">

        <!-- CONTENT -->
        <Grid Grid.Row="0"
              Padding="20"
              RowSpacing="14"
              RowDefinitions="Auto,Auto,Auto,Auto">

            <!-- ROW 0: NEXT PRAYER STATUS (refined) -->
            <Grid Grid.Row="0"
      RowDefinitions="Auto,Auto"
      RowSpacing="10">

                <!-- Top line -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Next prayer"
                   FontSize="12"
                   Opacity="0.60"
                   TextColor="{StaticResource OnSurfaceLight}" />

                        <Label Text="{Binding NextPrayerName}"
                   FontSize="32"
                   FontAttributes="Bold"
                   LineBreakMode="TailTruncation"
                   TextColor="{StaticResource OnSurfaceLight}" />
                    </VerticalStackLayout>

                    <Label Grid.Column="1"
               Text="{Binding NextPrayerTime}"
               FontSize="20"
               FontAttributes="Bold"
               Opacity="0.75"
               VerticalTextAlignment="Center"
               HorizontalTextAlignment="End"
               TextColor="{StaticResource OnSurfaceLight}" />
                </Grid>

                <!-- Countdown pill -->
                <Border Grid.Row="1"
                        Padding="12,8"
                        BackgroundColor="{StaticResource White}"
                        StrokeThickness="0">    
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>

                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <!-- simple dot as icon (no extra asset) -->
                        <BoxView WidthRequest="8"
                             HeightRequest="8"
                             CornerRadius="4"
                             Opacity="0.75"
                             Color="{StaticResource Primary}" />    

                        <Label Text="{Binding NextPrayerCountdown}"
                               FontSize="14"
                               Opacity="0.85"
                               TextColor="{StaticResource OnSurfaceLight}" />   
                    </HorizontalStackLayout>
                </Border>

            </Grid>

            <!-- ROW 1: TODAY CARD -->
            <Frame Grid.Row="1"
                   Padding="16"
                   HasShadow="True"
                   BackgroundColor="{StaticResource White}">

                <VerticalStackLayout Spacing="14">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <Label Text="Today"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Grid.Column="1"
                               Text="Madrid"
                               FontSize="12"
                               Opacity="0.65"
                               VerticalOptions="Center"
                               TextColor="{StaticResource OnSurfaceLight}" />
                    </Grid>

                    <!-- Times list (placeholder) -->
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="Auto,*,Auto"
                          RowSpacing="12">

                        <Label Grid.Row="0" Grid.Column="0" Text="Fajr" Opacity="0.85"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <BoxView Grid.Row="0" Grid.Column="1"
                                 HeightRequest="1"
                                 Opacity="0.10"
                                 VerticalOptions="Center"
                                 BackgroundColor="{StaticResource OnSurfaceLight}" />
                        <Label Grid.Row="0" Grid.Column="2" Text="06:21" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Dhuhr" Opacity="0.85"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <BoxView Grid.Row="1" Grid.Column="1"
                                 HeightRequest="1"
                                 Opacity="0.10"
                                 VerticalOptions="Center"
                                 BackgroundColor="{StaticResource OnSurfaceLight}" />
                        <Label Grid.Row="1" Grid.Column="2" Text="13:58" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Asr" Opacity="0.85"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <BoxView Grid.Row="2" Grid.Column="1"
                                 HeightRequest="1"
                                 Opacity="0.10"
                                 VerticalOptions="Center"
                                 BackgroundColor="{StaticResource OnSurfaceLight}" />
                        <Label Grid.Row="2" Grid.Column="2" Text="17:22" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Maghrib" Opacity="0.85"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <BoxView Grid.Row="3" Grid.Column="1"
                                 HeightRequest="1"
                                 Opacity="0.10"
                                 VerticalOptions="Center"
                                 BackgroundColor="{StaticResource OnSurfaceLight}" />
                        <Label Grid.Row="3" Grid.Column="2" Text="19:42" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="Isha" Opacity="0.85"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <BoxView Grid.Row="4" Grid.Column="1"
                                 HeightRequest="1"
                                 Opacity="0.10"
                                 VerticalOptions="Center"
                                 BackgroundColor="{StaticResource OnSurfaceLight}" />
                        <Label Grid.Row="4" Grid.Column="2" Text="21:10" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceLight}" />
                    </Grid>

                    <!-- Meta -->
                    <HorizontalStackLayout Spacing="10" Opacity="0.65">
                        <Label Text="Method: MWL" FontSize="12"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Text="•" FontSize="12"
                               TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Text="Asr: Shafi" FontSize="12"
                               TextColor="{StaticResource OnSurfaceLight}" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- ROW 2: BOTTOM ACTIONS -->
            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10">

                <Button Text="Qibla"
                        HeightRequest="54"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoQiblaCommand}" />

                <Button Grid.Column="1"
                        Text="Map"
                        HeightRequest="54"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoMapCommand}" />

                <Button Grid.Column="2"
                        Text="Alarms"
                        HeightRequest="54"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource OnPrimary}"
                        Command="{Binding GoTimesCommand}" />
            </Grid>

            <!-- ROW 3: ADS SLOT -->
            <Frame Grid.Row="3"
                   HeightRequest="64"
                   HasShadow="False"
                   Padding="0"
                   BackgroundColor="{StaticResource Black}"
                   Opacity="0.05" />

        </Grid>

    </Grid>
</ContentPage>