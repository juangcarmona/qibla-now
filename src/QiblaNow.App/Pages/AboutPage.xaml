<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:QiblaNow.App.Resources.Localization"
             x:Class="QiblaNow.App.Pages.AboutPage"
             Title="{x:Static loc:AppResources.AboutPage_Title}"
             BackgroundColor="{StaticResource AppBackgroundLight}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,20" Spacing="16">

            <!-- App identity -->
            <Border Padding="18,24"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10"
                                     HorizontalOptions="Center">
                    <Image Source="about_logo.png"
                           HeightRequest="80"
                           WidthRequest="80"
                           HorizontalOptions="Center"
                           Aspect="AspectFit" />

                    <Label Text="{x:Static loc:AppResources.AppTitle}"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_Version}"
                           FontSize="14"
                           TextColor="{StaticResource Gray600}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_Description}"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Features -->
            <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static loc:AppResources.AboutPage_Features}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_FeaturePrayerTimes}"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_FeatureQibla}"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_FeatureNotifications}"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_FeatureCalculationMethods}"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_FeatureOffline}"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />
                </VerticalStackLayout>
            </Border>

            <!-- Links -->
            <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static loc:AppResources.AboutPage_Links}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AboutPage_SourceCode}"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Label Text="github.com/juangcarmona/qibla-now"
                               FontSize="14"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGithubTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AboutPage_Website}"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Label Text="jgcarmona.com"
                               FontSize="14"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWebsiteTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Support -->
            <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static loc:AppResources.AboutPage_Support}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="{x:Static loc:AppResources.AboutPage_SupportDescription}"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}"
                           LineBreakMode="WordWrap" />

                    <Button Text="{x:Static loc:AppResources.AboutPage_SupportButton}"
                            Clicked="OnDonateClicked"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            HeightRequest="48" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>