<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QiblaNow.App.Pages.AboutPage"
             Title="About"
             BackgroundColor="{StaticResource AppBackgroundLight}">

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,20" Spacing="16">

            <!-- App identity -->
            <Border Padding="18,24"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10"
                                     HorizontalOptions="Center">
                    <Image Source="splash.png"
                           HeightRequest="80"
                           WidthRequest="80"
                           HorizontalOptions="Center"
                           Aspect="AspectFit" />

                    <Label Text="Qibla Now"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="Version 1.0"
                           FontSize="14"
                           TextColor="{StaticResource Gray600}"
                           HorizontalTextAlignment="Center" />

                    <Label Text="An offline-first Islamic utility for prayer times and Qibla direction."
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Features -->
            <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Features"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="• Accurate prayer times for any location"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="• Qibla compass direction"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="• Prayer time notifications"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="• Multiple calculation methods"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="• Works fully offline"
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}" />
                </VerticalStackLayout>
            </Border>

            <!-- Links -->
            <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Links"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Source code"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Label Text="github.com/juangcarmona/qibla-now"
                               FontSize="14"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGithubTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Website"
                               FontSize="13"
                               TextColor="{StaticResource Gray600}" />
                        <Label Text="jgcarmona.com"
                               FontSize="14"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWebsiteTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Support -->
            <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Support"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                    <Label Text="Qibla Now is free and open source. If it helps you, you can support its development."
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceLight}"
                           LineBreakMode="WordWrap" />

                    <Button Text="Support this project"
                            Clicked="OnDonateClicked"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            HeightRequest="48" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>