<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:QiblaNow.Presentation.ViewModels;assembly=QiblaNow.Presentation"
             x:Class="QiblaNow.App.Pages.SoundSettingsPage"
             xmlns:app="clr-namespace:QiblaNow.App"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:QiblaNow.App.Resources.Localization"
             Title="{x:Static loc:AppResources.SoundSettings_Title}"
             BackgroundColor="{StaticResource AppBackgroundLight}"
             x:DataType="viewmodels:SettingsViewModel">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,16,20,20" Spacing="16">

                <!-- Prayer Notifications -->
                <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="14">
                        <Label Text="{x:Static loc:AppResources.SoundSettings_PrayerNotifications}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />

                        <Label Text="{x:Static loc:AppResources.SoundSettings_NotificationsDescription}"
                           FontSize="13" TextColor="{StaticResource Gray600}"
                           LineBreakMode="WordWrap" />

                        <BoxView HeightRequest="0.5" Color="{StaticResource Gray200}" Margin="0,2" />

                        <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="12"
                          Margin="0,2,0,0">

                            <Label Grid.Row="0" Grid.Column="0"
                               Text="{x:Static loc:AppResources.Prayer_Fajr}" FontSize="15"
                               TextColor="{StaticResource OnSurfaceLight}"
                               VerticalOptions="Center" />
                            <Switch Grid.Row="0" Grid.Column="1"
                                IsToggled="{Binding FajrEnabled}"
                                OnColor="{StaticResource Primary}" />

                            <Label Grid.Row="1" Grid.Column="0"
                               Text="{x:Static loc:AppResources.Prayer_Dhuhr}" FontSize="15"
                               TextColor="{StaticResource OnSurfaceLight}"
                               VerticalOptions="Center" />
                            <Switch Grid.Row="1" Grid.Column="1"
                                IsToggled="{Binding DhuhrEnabled}"
                                OnColor="{StaticResource Primary}" />

                            <Label Grid.Row="2" Grid.Column="0"
                               Text="{x:Static loc:AppResources.Prayer_Asr}" FontSize="15"
                               TextColor="{StaticResource OnSurfaceLight}"
                               VerticalOptions="Center" />
                            <Switch Grid.Row="2" Grid.Column="1"
                                IsToggled="{Binding AsrEnabled}"
                                OnColor="{StaticResource Primary}" />

                            <Label Grid.Row="3" Grid.Column="0"
                               Text="{x:Static loc:AppResources.Prayer_Maghrib}" FontSize="15"
                               TextColor="{StaticResource OnSurfaceLight}"
                               VerticalOptions="Center" />
                            <Switch Grid.Row="3" Grid.Column="1"
                                IsToggled="{Binding MaghribEnabled}"
                                OnColor="{StaticResource Primary}" />

                            <Label Grid.Row="4" Grid.Column="0"
                               Text="{x:Static loc:AppResources.Prayer_Isha}" FontSize="15"
                               TextColor="{StaticResource OnSurfaceLight}"
                               VerticalOptions="Center" />
                            <Switch Grid.Row="4" Grid.Column="1"
                                IsToggled="{Binding IshaEnabled}"
                                OnColor="{StaticResource Primary}" />

                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Adhan Sound -->
                <Border Padding="18,16"
                    BackgroundColor="{StaticResource White}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="14">
                        <Label Text="{x:Static loc:AppResources.SoundSettings_Adhan}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceLight}" />
                        <Label Text="{x:Static loc:AppResources.SoundSettings_AdhanDescription}"
                           FontSize="13" TextColor="{StaticResource Gray600}"
                           LineBreakMode="WordWrap" />

                        <BoxView HeightRequest="0.5" Color="{StaticResource Gray200}" Margin="0,2" />

                        <!-- Each row: tap anywhere on the label to select; ▶ button to preview -->
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              RowSpacing="12"
                              Margin="0,2,0,0">

                            <!-- System Default -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{x:Static loc:AppResources.SoundSettings_AdhanDefault}"
                                   FontSize="15"
                                   TextColor="{StaticResource OnSurfaceLight}"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsDefaultSoundSelected}"
                                                 Value="True">
                                        <Setter Property="FontAttributes" Value="Bold" />
                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                </Label.Triggers>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectDefaultSoundCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Button Grid.Row="0" Grid.Column="1"
                                    Text="{x:Static loc:AppResources.SoundSettings_Preview}"
                                    Command="{Binding PreviewDefaultSoundCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="36" WidthRequest="44"
                                    Padding="0" FontSize="14" />

                            <!-- Adhan 1 -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{x:Static loc:AppResources.SoundSettings_Adhan1}"
                                   FontSize="15"
                                   TextColor="{StaticResource OnSurfaceLight}"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsAdhan1Selected}"
                                                 Value="True">
                                        <Setter Property="FontAttributes" Value="Bold" />
                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                </Label.Triggers>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectAdhan1Command}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Button Grid.Row="1" Grid.Column="1"
                                    Text="{x:Static loc:AppResources.SoundSettings_Preview}"
                                    Command="{Binding PreviewAdhan1Command}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="36" WidthRequest="44"
                                    Padding="0" FontSize="14" />

                            <!-- Adhan 2 -->
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="{x:Static loc:AppResources.SoundSettings_Adhan2}"
                                   FontSize="15"
                                   TextColor="{StaticResource OnSurfaceLight}"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsAdhan2Selected}"
                                                 Value="True">
                                        <Setter Property="FontAttributes" Value="Bold" />
                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                </Label.Triggers>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectAdhan2Command}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Button Grid.Row="2" Grid.Column="1"
                                    Text="{x:Static loc:AppResources.SoundSettings_Preview}"
                                    Command="{Binding PreviewAdhan2Command}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="36" WidthRequest="44"
                                    Padding="0" FontSize="14" />

                            <!-- Adhan 3 -->
                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="{x:Static loc:AppResources.SoundSettings_Adhan3}"
                                   FontSize="15"
                                   TextColor="{StaticResource OnSurfaceLight}"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsAdhan3Selected}"
                                                 Value="True">
                                        <Setter Property="FontAttributes" Value="Bold" />
                                        <Setter Property="TextColor" Value="{StaticResource Primary}" />
                                    </DataTrigger>
                                </Label.Triggers>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectAdhan3Command}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Button Grid.Row="3" Grid.Column="1"
                                    Text="{x:Static loc:AppResources.SoundSettings_Preview}"
                                    Command="{Binding PreviewAdhan3Command}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="36" WidthRequest="44"
                                    Padding="0" FontSize="14" />

                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="0,4">
            <admob:MTAdView
               x:Name="BottomBanner"                
                HorizontalOptions="Center" />
        </Border>

    </Grid>
</ContentPage>
